{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "baseUrl": ".",
    "paths": {
      "core/*": ["core/*"],
      "features/*": ["features/*"],
      "pages/*": ["pages/*"]
    },
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": [
    "*.js",
    "core/**/*.js",
    "features/**/*.js",
    "pages/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "legacy"
  ]
}
