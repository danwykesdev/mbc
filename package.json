  "main": "main.js",
  "scripts": {
    "build": "npm run build:runtime",
    "build:dev": "npm run build:runtime:dev",
    "build:runtime": "esbuild bundle-runtime-entry.js --bundle --minify --format=iife --target=es2018 \"--banner:js=window.__MBC_BUNDLED_RUNTIME__=true;\" --outfile=dist/mbc.runtime.js",
    "build:runtime:dev": "esbuild bundle-runtime-entry.js --bundle --format=iife --sourcemap --target=es2018 \"--banner:js=window.__MBC_BUNDLED_RUNTIME__=true;\" --outfile=dist/mbc.runtime.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danwykesdev/mbc.git"
  },
